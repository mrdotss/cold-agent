# Cloud Bill Analyst - web app environment (EXAMPLE - committed).
# Copy to .env and fill in real values. Never commit .env.

# ---- App / Auth ----
# PostgreSQL connection string used by Drizzle.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/cba"
# Auth.js secret. Generate: `npx auth secret`  (or any random 32-byte base64).
AUTH_SECRET="generate-a-random-32-byte-base64-secret"
# Optional canonical URL (Auth.js v5 auto-detects in dev).
# AUTH_URL="http://localhost:3000"
# AES-256 key (32 bytes, base64) encrypting each connected account's external_id at rest.
APP_ENCRYPTION_KEY="generate-a-random-32-byte-base64-key"

# ---- Cloud Bill Analyst agent (server-side only) ----
AWS_REGION="us-east-1"
# Deployed AgentCore runtime ARN
#   (aws bedrock-agentcore-control list-agent-runtimes --region us-east-1).
CBA_RUNTIME_ARN="arn:aws:bedrock-agentcore:us-east-1:<ACCOUNT_ID>:runtime/<RUNTIME_ID>"
# Runtime execution role ARN - trust principal used in the account-connection
# CloudFormation template (see agentcore-integration steering).
CBA_RUNTIME_ROLE_ARN="arn:aws:iam::<ACCOUNT_ID>:role/<RUNTIME_EXECUTION_ROLE>"
# App-owned bucket for report files (used to presign downloads).
CBA_REPORT_BUCKET="<your-report-bucket>"

# ---- AWS credentials (server-side; choose ONE) ----
# Preferred: a shared-credentials / SSO profile.
# AWS_PROFILE="default"
# Or explicit keys (never commit real values):
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
