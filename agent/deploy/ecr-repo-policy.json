{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowAgentCoreRuntimePull",
      "Effect": "Allow",
      "Principal": { "Service": "bedrock-agentcore.amazonaws.com" },
      "Action": [
        "ecr:BatchGetImage",
        "ecr:GetDownloadUrlForLayer",
        "ecr:BatchCheckLayerAvailability"
      ],
      "Condition": { "StringEquals": { "aws:SourceAccount": "279199663312" } }
    }
  ]
}
